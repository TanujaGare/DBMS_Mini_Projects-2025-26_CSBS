<% layout('layouts/boilerplate') %>

<div class="row pt-5">
    <div class="col-6 offset-3">
        <div class="alert alert-danger" role="alert">
            <h4 class="alert-heading text-center"><i class="fa-solid fa-triangle-exclamation"></i> Oops, something went wrong!</h4>
            <hr>
            <p class="mb-0 text-center"><%= message %></p>
        </div>
        
        <% if(process.env.NODE_ENV !== "production") { %>
            <div class="card mt-4 border-danger">
                <div class="card-header text-bg-danger font-monospace">Stack Trace</div>
                <div class="card-body bg-light">
                    <!-- Ensure we actually have an error object passed in if possible, fallback to just message -->
                    <pre class="font-monospace text-wrap small text-muted"><%= typeof err !== 'undefined' ? err.stack : 'No stack trace available.' %></pre>
                </div>
            </div>
        <% } %>
    </div>
</div>
