<% layout('layouts/boilerplate') %>

<div class="row mt-4 mb-5">
    <div class="col-8 offset-2">
        <h3 class="fw-bold mb-4">Create a New Listing</h3>
        
        <form method="POST" action="/listings" class="needs-validation shadow-sm p-5 rounded-4 border bg-white" novalidate>
            <div class="mb-3">
                <label for="title" class="form-label fw-semibold">Title</label>
                <input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control rounded-3 py-2" required>
                <div class="valid-feedback">Title looks good!</div>
                <div class="invalid-feedback">Please enter a valid title.</div>
            </div>

            <div class="mb-3">
                <label for="description" class="form-label fw-semibold">Description</label>
                <textarea name="listing[description]" placeholder="Describe your place to the guests" class="form-control rounded-3" rows="4" required></textarea>
                <div class="invalid-feedback">Please enter a short description.</div>
            </div>

            <div class="mb-4">
                <label for="image" class="form-label fw-semibold">Image Link</label>
                <input type="text" name="listing[image]" placeholder="Link to an image (URL)" class="form-control rounded-3 py-2">
                <div class="form-text mt-1 text-muted"><i class="fa-solid fa-circle-info me-1"></i> Leave empty to use our beautiful default image.</div>
            </div>

            <div class="row mb-3">
                <div class="mb-3 col-md-4">
                    <label for="price" class="form-label fw-semibold">Price (per night)</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0">&#8377;</span>
                        <input type="number" name="listing[price]" placeholder="1500" class="form-control border-start-0 ps-0 rounded-end-3 py-2" required min="0">
                        <div class="invalid-feedback">Please enter a valid price.</div>
                    </div>
                </div>

                <div class="mb-3 col-md-8">
                    <label for="country" class="form-label fw-semibold">Country</label>
                    <input type="text" name="listing[country]" placeholder="India, USA, Japan..." class="form-control rounded-3 py-2" required>
                    <div class="invalid-feedback">Country name should be valid.</div>
                </div>
            </div>

            <div class="mb-4">
                <label for="location" class="form-label fw-semibold">Location</label>
                <input type="text" name="listing[location]" placeholder="City, State" class="form-control rounded-3 py-2" required>
                <div class="invalid-feedback">Location should be valid.</div>
            </div>

            <button class="btn btn-danger w-100 py-2 rounded-pill fw-bold mt-2 fs-5 shadow-sm">Add Listing</button>
        </form>
    </div>
</div>
