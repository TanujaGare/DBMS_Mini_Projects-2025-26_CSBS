<% layout('layouts/boilerplate') %>

<% if(typeof search !== 'undefined' && search !== "") { %>
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h3 class="mb-0">Search results for "<%= search %>"</h3>
        <a href="/listings" class="btn btn-outline-secondary btn-sm">Clear Search</a>
    </div>
<% } else { %>
    <h2 class="mb-4 fw-bold">Explore Top Destinations</h2>
<% } %>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-1">
    <% if(allListings.length === 0) { %>
        <div class="col-12 w-100 text-center py-5">
            <h4 class="text-muted"><i class="fa-solid fa-magnifying-glass mb-3 fa-2x"></i><br>No listings found.</h4>
            <p class="text-muted">Try adjusting your search terms or <a href="/listings/new" class="text-decoration-none">create a new listing</a>.</p>
        </div>
    <% } %>

    <% for(let listing of allListings) { %>
        <div class="col">
            <a href="/listings/<%= listing._id %>" class="text-decoration-none user-select-none h-100 d-block">
                <div class="card h-100 listing-card border-0 shadow-sm rounded-4 overflow-hidden">
                    <img src="<%= listing.image %>" class="card-img-top object-fit-cover" alt="listing_image" style="height: 20rem;">
                    <div class="card-body bg-white pb-3 pt-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h5 class="card-title fw-semibold text-dark text-truncate mb-0" style="max-width: 80%;"><%= listing.title %></h5>
                            <span class="badge bg-danger rounded-pill"><i class="fa-solid fa-star text-white small"></i> New</span>
                        </div>
                        <p class="card-text text-muted mb-2 small"><i class="fa-solid fa-location-dot text-danger me-1"></i> <%= listing.location %>, <%= listing.country %></p>
                        <p class="card-text text-dark fw-bold mb-0">
                            &#8377; <%= listing.price.toLocaleString("en-IN") %> <span class="fw-normal text-muted small">/ night</span>
                        </p>
                    </div>
                </div>
            </a>
        </div>
    <% } %>
</div>
