<% layout('layouts/boilerplate') %>

<div class="row mt-3 mb-5">
    <!-- Main Listing Content -->
    <div class="col-8 offset-2">
        <h3 class="fw-bold mb-3"><%= listing.title %></h3>
        
        <div class="card listing-card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <img src="<%= listing.image %>" class="card-img-top object-fit-cover" alt="listing_image" style="height: 50vh;">
            <div class="card-body mt-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <p class="card-text fw-semibold mb-0">Owned by <span class="text-danger">@<%= listing.owner.username %></span></p>
                    <% if(avgRating > 0) { %>
                        <span class="badge bg-dark rounded-pill px-3 py-2 fs-6"><i class="fa-solid fa-star text-warning me-1"></i> <%= avgRating %></span>
                    <% } else { %>
                        <span class="badge bg-secondary rounded-pill px-3 py-2">New</span>
                    <% } %>
                </div>
                
                <p class="card-text text-muted"><%= listing.description %></p>
                
                <div class="d-flex gap-4 mb-4">
                    <p class="card-text mb-0"><i class="fa-solid fa-tag text-danger me-2"></i> <b>&#8377; <%= listing.price.toLocaleString("en-IN") %></b> / night</p>
                    <p class="card-text mb-0"><i class="fa-solid fa-map-location-dot text-danger me-2"></i> <%= listing.location %>, <%= listing.country %></p>
                </div>

                <!-- Action Buttons (Only visible to owner) -->
                <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
                    <div class="mt-4 d-flex gap-3">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark px-4 rounded-pill">Edit</a>
                        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="m-0">
                            <button class="btn btn-outline-danger px-4 rounded-pill">Delete</button>
                        </form>
                    </div>
                <% } %>
            </div>
        </div>
        
        <hr>

        <!-- Leave a Review Section -->
        <% if(currUser) { %>
            <div class="mt-4 mb-5">
                <h4 class="fw-bold mb-4">Leave a Review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation shadow-sm p-4 rounded-4 border bg-light" novalidate>
                    <div class="mb-3">
                        <label for="rating" class="form-label fw-semibold">Rating: <span id="ratingVal" class="text-danger fw-bold">3</span> / 5</label>
                        <input type="range" min="1" max="5" value="3" step="1" id="rating" name="review[rating]" class="form-range custom-range" oninput="document.getElementById('ratingVal').textContent = this.value">
                        <div class="d-flex justify-content-between small text-muted px-1 mt-1">
                            <span>1 <i class="fa-solid fa-star text-warning"></i></span>
                            <span>2</span>
                            <span>3</span>
                            <span>4</span>
                            <span>5 <i class="fa-solid fa-star text-warning"></i></span>
                        </div>
                    </div>
                    
                    <div class="mb-3 mt-4">
                        <label for="comment" class="form-label fw-semibold">Comments</label>
                        <textarea name="review[comment]" id="comment" cols="30" rows="4" class="form-control rounded-3" required placeholder="Share your experience..."></textarea>
                        <div class="invalid-feedback">Please add some comments for your review.</div>
                    </div>
                    <button class="btn btn-danger rounded-pill px-4 mt-2">Submit Review</button>
                </form>
            </div>
            <hr>
        <% } %>

        <!-- Display Reviews -->
        <% if(listing.reviews.length > 0) { %>
            <div class="mb-4">
                <h4 class="fw-bold mb-4">All Reviews</h4>
                <div class="row g-4">
                    <% for(let review of listing.reviews) { %>
                        <div class="col-12 col-md-6">
                            <div class="card h-100 border-0 shadow-sm rounded-4 pb-2">
                                <div class="card-body">
                                    <h6 class="card-title fw-bold mb-1"><i class="fa-solid fa-circle-user text-muted fs-5 me-2 align-middle"></i>@<%= review.author.username %></h6>
                                    
                                    <div class="mb-2 mt-2">
                                        <% for(let i=1; i<=5; i++) { %>
                                            <% if(i <= review.rating) { %>
                                                <i class="fa-solid fa-star text-warning small"></i>
                                            <% } else { %>
                                                <i class="fa-regular fa-star text-muted small"></i>
                                            <% } %>
                                        <% } %>
                                    </div>
                                    
                                    <p class="card-text text-muted mb-3">"<%= review.comment %>"</p>
                                    
                                    <!-- Delete Review Button (Only visible to review author) -->
                                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <button class="btn btn-sm btn-outline-danger py-0 px-2 rounded-pill small">Delete</button>
                                        </form>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</div>

<script>
    // Custom logic to enhance range input styling if needed can go in script.js
</script>
